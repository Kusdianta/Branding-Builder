APP_NAME=BrandKit-AI
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://brandkit-ai.test

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
# BB139 — must exceed the longest job timeout (FetchGMapsReviewsJob = 600s) so a
# slow scrape is not re-reserved and re-run by a second parallel worker.
DB_QUEUE_RETRY_AFTER=660

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# =============================================================
# ANTHROPIC / CLAUDE AI — PASTE YOUR API KEY BELOW
# Get your key at: https://console.anthropic.com/settings/keys
# =============================================================
ANTHROPIC_API_KEY=your-key-here
# Model overrides (optional). Defaults live in config/services.php.
# `model` drives the deterministic pillar scorer; `model_analysis` the IG
# analysis call (can be upgraded independently via vault _shared.json).
ANTHROPIC_MODEL=claude-sonnet-4-6
ANTHROPIC_MODEL_ANALYSIS=claude-sonnet-4-6

# =============================================================
# SSO — auth via the Hub gateway (BB02/BB03)
# Google OAuth now lives ONLY in nema-hub. This spoke is bounced to the
# Hub for login and validates the Hub's signed token with
# SSO_SHARED_SECRET (same value in the Hub and EVERY spoke — a deploy-time
# secret like APP_KEY, NOT stored in the vault).
# Generate via: php -r "echo bin2hex(random_bytes(32));"
# =============================================================
SSO_SHARED_SECRET=
# Hub SSO entry point. Defaults to the Hub's .test host in dev; set
# explicitly in prod, e.g. https://nema.creativeapq.online/auth/sso/redirect
HUB_SSO_URL=http://nema-hub.test/auth/sso/redirect
# Hub base URL (platform-wide logout notify + internal API calls).
HUB_URL=http://nema-hub.test

# =============================================================
# HUB INBOUND API KEY — Phase 12a (BB84)
# Same value must be set in nema-hub/.env as HUB_BB_USERS_API_KEY.
# Generate via: php -r "echo bin2hex(random_bytes(32));"
# =============================================================
HUB_USERS_API_KEY=

# =============================================================
# GOOGLE MAPS / PLACES API — Phase 12c (BB89)
# Used by the public-facing audit wizard for Places Autocomplete
# on Step 1 and for the server-side Place Details + Text Search
# fallback that resolves pasted maps.app.goo.gl shortlinks.
#
# 1. Create a SEPARATE API key (don't reuse the OAuth client) at:
#      https://console.cloud.google.com/apis/credentials
#    Name it: branding-builder-maps-public
#
# 2. Enable on the key: Maps JavaScript API + Places API (New)
#
# 3. Restrict by HTTP referrer:
#      https://ksdnt-pongo.tailb72bec.ts.net/*   (dev via Tailscale Funnel)
#      https://branding.nema.creativeapq.online/* (prod)
#      http://branding-builder.test/*            (local Herd)
#
# 4. Set quota: 10k requests/day initially. Revisit after BB97 ships
#    the places_api_calls log channel so cost is observable.
#
# Country bias narrows autocomplete to a single country (ISO 3166-1
# alpha-2). 'id' = Indonesia. Override per market if expanding.
# =============================================================
GOOGLE_MAPS_API_KEY=
GOOGLE_MAPS_COUNTRY_BIAS=id

# BB107 -> BB113 — Step 3 TikTok input visibility. BB113 fixed TikTokHandleChecker
# (JSON user/detail endpoint), so TikTok is now a live availability-check signal
# (+10 Digital Presence, no scrape). config/features.php defaults this to true;
# set WIZARD_SHOW_TIKTOK=false to hide the input again.
WIZARD_SHOW_TIKTOK=true

# =============================================================
# NEMA WORKER (FastAPI) — Phase 7-B. The spoke calls the worker for
# IG/TikTok/GMaps/website scraping + screenshots via nema/worker-client.
# In production these come from vault/_shared.json; the values below are
# local-dev fallbacks (see config/services.php `nema_worker` block).
# =============================================================
NEMA_WORKER_URL=http://localhost:9878
NEMA_WORKER_API_KEY=
NEMA_WORKER_TIMEOUT=10

# Bearer the spoke expects on inbound Hub->spoke health probes
# (config/services.php `hub.inbound_api_key`; vault-overridden in prod).
HUB_INBOUND_API_KEY=
