APP_NAME=BrandKit-AI
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://brandkit-ai.test

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
# BB139 — must exceed the longest job timeout (FetchGMapsReviewsJob = 600s) so a
# slow scrape is not re-reserved and re-run by a second parallel worker.
DB_QUEUE_RETRY_AFTER=660

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# =============================================================
# ANTHROPIC / CLAUDE AI — PASTE YOUR API KEY BELOW
# Get your key at: https://console.anthropic.com/settings/keys
# =============================================================
ANTHROPIC_API_KEY=your-key-here

# =============================================================
# GOOGLE OAUTH — Phase 12a (BB81)
# 1. Register an OAuth 2.0 Client at:
#      https://console.cloud.google.com/apis/credentials
# 2. Authorized JavaScript origins:
#      https://ksdnt-pongo.tailb72bec.ts.net   (dev via Tailscale Funnel)
#      https://branding.nema.creativeapq.online (prod)
# 3. Authorized redirect URIs (must match GOOGLE_REDIRECT_URL exactly):
#      https://ksdnt-pongo.tailb72bec.ts.net/auth/google/callback
#      https://branding.nema.creativeapq.online/auth/google/callback
# Google rejects non-HTTPS callbacks (except localhost), so the .test URL
# cannot be used for OAuth — sign-in must be tested via the funnel.
# =============================================================
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URL=https://ksdnt-pongo.tailb72bec.ts.net/auth/google/callback

# =============================================================
# HUB INBOUND API KEY — Phase 12a (BB84)
# Same value must be set in nema-hub/.env as HUB_BB_USERS_API_KEY.
# Generate via: php -r "echo bin2hex(random_bytes(32));"
# =============================================================
HUB_USERS_API_KEY=

# =============================================================
# GOOGLE MAPS / PLACES API — Phase 12c (BB89)
# Used by the public-facing audit wizard for Places Autocomplete
# on Step 1 and for the server-side Place Details + Text Search
# fallback that resolves pasted maps.app.goo.gl shortlinks.
#
# 1. Create a SEPARATE API key (don't reuse the OAuth client) at:
#      https://console.cloud.google.com/apis/credentials
#    Name it: branding-builder-maps-public
#
# 2. Enable on the key: Maps JavaScript API + Places API (New)
#
# 3. Restrict by HTTP referrer:
#      https://ksdnt-pongo.tailb72bec.ts.net/*   (dev via Tailscale Funnel)
#      https://branding.nema.creativeapq.online/* (prod)
#      http://branding-builder.test/*            (local Herd)
#
# 4. Set quota: 10k requests/day initially. Revisit after BB97 ships
#    the places_api_calls log channel so cost is observable.
#
# Country bias narrows autocomplete to a single country (ISO 3166-1
# alpha-2). 'id' = Indonesia. Override per market if expanding.
# =============================================================
GOOGLE_MAPS_API_KEY=
GOOGLE_MAPS_COUNTRY_BIAS=id

# BB107 — hide TikTok input on the Step 3 wizard. The /check-handle/tiktok
# route + scoring services stay live; set this to true once BB108 fixes
# TikTokHandleChecker (current implementation has the pre-BB107 fixture-rot
# bug — see config/features.php for context).
WIZARD_SHOW_TIKTOK=false
