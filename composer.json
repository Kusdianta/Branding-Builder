{
    "$schema": "https://getcomposer.org/schema.json",
    "name": "laravel/laravel",
    "type": "project",
    "description": "Branding Builder — AI Brand Health Check spoke for the Nema platform.",
    "keywords": ["laravel", "framework", "nema"],
    "license": "MIT",
    "repositories": [
        {
            "type": "path",
            "url": "../nema-ui-kit",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "../nema-worker-client",
            "options": {
                "symlink": true
            }
        }
    ],
    "require": {
        "php": "^8.3",
        "anthropic-ai/sdk": "^0.8.0",
        "barryvdh/laravel-dompdf": "^3.1",
        "guzzlehttp/guzzle": "^7.10",
        "laravel/framework": "^13.0",
        "laravel/tinker": "^3.0",
        "livewire/livewire": "^4.3",
        "livewire/volt": "^1.10",
        "nema/ui-kit": "@dev",
        "nema/worker-client": "@dev"
    },
    "require-dev": {
        "fakerphp/faker": "^1.23",
        "laravel/pail": "^1.2.5",
        "laravel/pint": "^1.27",
        "mockery/mockery": "^1.6",
        "nunomaduro/collision": "^8.6",
        "phpunit/phpunit": "^12.5.12"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "setup": [
            "composer install",
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\"",
            "@php artisan key:generate",
            "@php artisan migrate --force",
            "@php artisan db:seed --force",
            "@php artisan vendor:publish --tag=nema-ui-kit --force",
            "npm install --ignore-scripts",
            "npm run build"
        ],
        "dev": [
            "Composer\\Config::disableProcessTimeout",
            "npx concurrently -c \"#c4b5fd,#a78bfa,#8b5cf6,#fb7185,#fdba74\" \"php artisan queue:work --tries=1 --timeout=600\" \"php artisan queue:work --tries=1 --timeout=600\" \"php artisan queue:work --tries=1 --timeout=600\" \"npm run dev\" \"uv --project ../workers/nema-worker run python ../workers/nema-worker/run_dev.py\" --names=queue1,queue2,queue3,vite,worker"
        ],
        "dev:no-worker": [
            "Composer\\Config::disableProcessTimeout",
            "npx concurrently -c \"#c4b5fd,#a78bfa,#8b5cf6,#fb7185\" \"php artisan queue:work --tries=1 --timeout=600\" \"php artisan queue:work --tries=1 --timeout=600\" \"php artisan queue:work --tries=1 --timeout=600\" \"npm run dev\" --names=queue1,queue2,queue3,vite"
        ],
        "test": [
            "@php artisan config:clear --ansi",
            "@php artisan test"
        ],
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi"
        ],
        "post-update-cmd": [
            "@php artisan vendor:publish --tag=laravel-assets --ansi --force",
            "@php artisan vendor:publish --tag=nema-ui-kit --ansi --force"
        ],
        "post-install-cmd": [
            "@php artisan vendor:publish --tag=nema-ui-kit --ansi --force"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi",
            "@php -r \"file_exists('database/database.sqlite') || touch('database/database.sqlite');\"",
            "@php artisan migrate --graceful --ansi"
        ],
        "pre-package-uninstall": [
            "Illuminate\\Foundation\\ComposerScripts::prePackageUninstall"
        ]
    },
    "extra": {
        "laravel": {
            "dont-discover": []
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
