# ============================================================================
# branding-builder — production env template. Copy to .env.production.
# Mounted via env_file AFTER .env.shared (APP_KEY + SSO_SHARED_SECRET).
#
# NOT here (provided by the vault via VaultServiceProvider — do NOT duplicate):
#   ANTHROPIC_API_KEY, GOOGLE_MAPS_API_KEY  -> vault/branding-builder.json
#   NEMA_WORKER_URL/KEY/TIMEOUT, hub.inbound -> vault/_shared.json
# ============================================================================

APP_NAME="Branding Builder"
APP_ENV=production
APP_DEBUG=false
APP_URL=https://nema-branding.creativeapq.online

LOG_CHANNEL=stack
LOG_LEVEL=warning

DB_CONNECTION=sqlite
DB_DATABASE=/app/database/database.sqlite
# Must exceed the longest queue job (GMaps scrape = 600s) so a slow job is not
# re-reserved and re-run by a sibling parallel worker.
DB_QUEUE_RETRY_AFTER=660

SESSION_DRIVER=database
CACHE_STORE=database
QUEUE_CONNECTION=database

TRUSTED_PROXIES=*

# --- Hub SSO (SSO_SHARED_SECRET lives in .env.shared) -----------------------
HUB_SSO_URL=https://nema.creativeapq.online/auth/sso/redirect
HUB_URL=https://nema.creativeapq.online
# Bearer the Hub presents on Hub->spoke users/credits API. Must match the Hub's
# SPOKE_BRANDING_BUILDER_KEY.
HUB_USERS_API_KEY=

# --- Model + locale knobs (the API keys themselves come from the vault) -----
ANTHROPIC_MODEL=claude-sonnet-4-6
ANTHROPIC_MODEL_ANALYSIS=claude-sonnet-4-6
GOOGLE_MAPS_COUNTRY_BIAS=id
WIZARD_SHOW_TIKTOK=true
